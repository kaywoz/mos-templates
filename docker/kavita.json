{
  "name": "Kavita",
  "repo": "linuxserver/kavita:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:5000]",
  "icon": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/kavita.png",
  "category": [
    "Media"
  ],
  "project": "https://github.com/linuxserver/docker-kavita",
  "support": "https://github.com/linuxserver/docker-kavita/issues",
  "donate": "https://opencollective.com/Kavita#sponsor",
  "description": "Kavita is a fast, feature rich, cross-platform reading server. Built with a focus for being a full solution for all your reading needs. Set up your own server and share your reading collection with your friends and family!",
  "readme_url": "https://github.com/linuxserver/docker-kavita/blob/main/README.md",
  "paths": [
    {
      "name": "Config",
      "host": "/mnt/cache/appdata/kavita",
      "container": "/config",
      "mode": "rw",
      "description": "Kavita configuration directory.",
      "required": true
    },
    {
      "name": "Library",
      "host": "/mnt/user/media/books",
      "container": "/library",
      "mode": "rw",
      "description": "Path to your book/comic library.",
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "5000",
      "container": "5000",
      "protocol": "tcp",
      "description": "Web interface port for viewing media.",
      "required": false,
      "mask": false
    }
  ],
  "variables": [],
  "devices": [],
  "labels": []
}
