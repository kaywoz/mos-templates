{
  "name": "kavita",
  "repo": "ajvmilazz0/kavita:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:5000]",
  "readme_url": "https://github.com/Kareadita/Kavita/blob/develop/README.md",
  "icon": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/kavita.png",
  "category": [ "media" ],
  "project": "https://github.com/Kareadita/Kavita",
  "support": "https://github.com/Kareadita/Kavita/issues",
  "description": "Kavita is a fast, feature rich, cross-platform reading server. Built with a focus for being a full solution for all your reading needs. Set up your own server and share your reading collection with your friends and family!",
  "donate": "https://opencollective.com/Kavita#sponsor",
  "paths": [
    {
      "name": "Library",
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/library",
      "container": "/library",
      "description": "Docker socket for accessing container logs."
    },
    {
      "name": "Config",
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/kavita/data/directory",
      "container": "/kavita/config",
      "description": "Config directory"
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "protocol": "tcp",
      "host": "5000",
      "container": "5000",
      "description": "Web interface port for viewing media."
    }
  ],
  "variables": [],
  "devices": []
}
