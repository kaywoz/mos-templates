{
  "name": "Healthchecks",
  "repo": "lscr.io/linuxserver/healthchecks:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/healthchecks.png",
  "category": [
    "Utilities"
  ],
  "project": "https://github.com/healthchecks/healthchecks",
  "support": "https://github.com/healthchecks/healthchecks/issues",
  "donate": null,
  "description": "Healthchecks is a cron job monitoring service. It listens for HTTP requests and email messages from your cron jobs and scheduled tasks. When a ping does not arrive on time, Healthchecks sends out alerts.",
  "readme_url": "https://github.com/healthchecks/healthchecks/blob/master/README.md",
  "paths": [
    {
      "name": "Data",
      "host": "/mnt/cache/appdata/healthchecks-data",
      "container": "/data",
      "mode": "rw",
      "description": null,
      "required": true
    },
    {
      "name": "Config",
      "host": "/mnt/cache/appdata/healthchecks-data/config",
      "container": "/config",
      "mode": "rw",
      "description": null,
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "8000",
      "container": "8000",
      "protocol": "tcp",
      "description": "Web interface",
      "required": false,
      "mask": false
    },
    {
      "name": "SMTP Listener",
      "host": "2525",
      "container": "2525",
      "protocol": "tcp",
      "description": "SMTP Listener",
      "required": false,
      "mask": false
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "1000",
      "description": "User ID",
      "required": false,
      "mask": false
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "1000",
      "description": "Group ID",
      "required": false,
      "mask": false
    },
    {
      "name": "Timezone",
      "key": "TZ",
      "value": "Europe/Stockholm",
      "description": "Timezone",
      "required": false,
      "mask": false
    },
    {
      "name": "SITE_ROOT",
      "key": "SITE_ROOT",
      "value": "https://healthchecks.example.com",
      "description": "The base public URL of your Healthchecks instance",
      "required": false,
      "mask": false
    },
    {
      "name": "SITE_NAME",
      "key": "SITE_NAME",
      "value": "My Healthchecks",
      "description": "Name of Site",
      "required": false,
      "mask": false
    },
    {
      "name": "SUPERUSER_EMAIL",
      "key": "SUPERUSER_EMAIL",
      "value": "admin@example.com",
      "description": "Superuser contact email",
      "required": false,
      "mask": false
    },
    {
      "name": "SUPERUSER_PASSWORD",
      "key": "SUPERUSER_PASSWORD",
      "value": "",
      "description": "Superuser password",
      "required": false,
      "mask": false
    },
    {
      "name": "DEBUG",
      "key": "DEBUG",
      "value": "True",
      "description": "Debug option",
      "required": false,
      "mask": false
    },
    {
      "name": "PING_EMAIL_DOMAIN",
      "key": "PING_EMAIL_DOMAIN",
      "value": "localhost",
      "description": "Email used for pings",
      "required": false,
      "mask": false
    },
    {
      "name": "INTEGRATIONS_ALLOW_PRIVATE_IPS",
      "key": "INTEGRATIONS_ALLOW_PRIVATE_IPS",
      "value": "True",
      "description": "If integrations allow private IP's",
      "required": false,
      "mask": false
    },
    {
      "name": "SECRET_KEY",
      "key": "SECRET_KEY",
      "value": "",
      "description": "secures HTTP sessions",
      "required": false,
      "mask": false
    },
    {
      "name": "SITE_LOGO_URL",
      "key": "SITE_LOGO_URL",
      "value": "https://avatars.githubusercontent.com/u/64521603?v=4",
      "description": "Url for Site logo",
      "required": false,
      "mask": false
    },
    {
      "name": "REGISTRATION_OPEN",
      "key": "REGISTRATION_OPEN",
      "value": "False",
      "description": "If user registration is open",
      "required": false,
      "mask": false
    },
    {
      "name": "PING_ENDPOINT",
      "key": "PING_ENDPOINT",
      "value": "https://healthchecks.example.com/ping/",
      "description": "",
      "required": false,
      "mask": false
    },
    {
      "name": "ALLOWED_HOSTS",
      "key": "ALLOWED_HOSTS",
      "value": "*",
      "description": "",
      "required": false,
      "mask": false
    },
    {
      "name": "DEFAULT_FROM_EMAIL",
      "key": "DEFAULT_FROM_EMAIL",
      "value": "noreply@example.com",
      "description": "",
      "required": false,
      "mask": false
    },
    {
      "name": "EMAIL_HOST",
      "key": "EMAIL_HOST",
      "value": "smtp.example.com",
      "description": "",
      "required": false,
      "mask": false
    },
    {
      "name": "EMAIL_HOST_PASSWORD",
      "key": "EMAIL_HOST_PASSWORD",
      "value": "",
      "description": "",
      "required": false,
      "mask": false
    },
    {
      "name": "EMAIL_HOST_USER",
      "key": "EMAIL_HOST_USER",
      "value": "",
      "description": "",
      "required": false,
      "mask": false
    }
  ],
  "devices": [],
  "labels": []
}
