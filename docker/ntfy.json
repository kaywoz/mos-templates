{
  "name": "Ntfy",
  "repo": "binwiederhier/ntfy :latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped ",
  "post_parameters": null,
  "web_ui_url": null,
  "readme_url": "https://github.com/binwiederhier/ntfy/blob/main/README.md",
  "icon": "https://github.com/binwiederhier/ntfy/raw/main/web/public/static/images/ntfy.png",
  "category": [ "utilities" ],
  "project": "https://github.com/binwiederhier/ntfy",
  "support": "https://github.com/binwiederhier/ntfy/issues",
  "description": "ntfy is a simple HTTP-based pub-sub notification service. With ntfy, you can send notifications to your phone or desktop via scripts from any computer, without having to sign up or pay any fees. ",
  "donate": null,
  "paths": [
    {
      "name": "Config directory" ,
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/ntfy",
      "container": "/etc/ntfy",
      "description": "Config directory"
    },
    {
      "name": "Cache directory" ,
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/ntfy/cache",
      "container": "/var/cache/ntfy",
      "description": "Cache directory"
    }
  ],
  "ports": [
     {
      "name": "Web Port",
      "protocol": "udp",
      "host": "80",
      "container": "80",
      "description": "Web Port"
    }
  ],
  "variables": [
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Etc/UTC",
      "description": "Timezone",
      "required": true,
      "mask": false
    }
  ],
  "command": [
    {
      "name": "serve",
      "key": "serve"
    }
  ]
}
