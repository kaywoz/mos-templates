{
  "name": "OpenObserve",
  "repo": "openobserve/openobserve:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped ",
  "post_parameters": null,
  "web_ui_url": null,
  "readme_url": "https://github.com/openobserve/openobserve/blob/main/README.md",
  "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/openobserve.png",
  "category": [ "utilities" ],
  "project": "https://github.com/openobserve/openobserve",
  "support": "https://github.com/openobserve/openobserve/issues",
  "description": "Open source Datadog alternative for logs, metrics, traces, and frontend monitoring. Modern observability platform: 10x easier, 140x lower storage cost, high performance, petabyte scale.",
  "donate": null,
  "paths": [
    {
      "name": "Data directory" ,
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/openobserve/data",
      "container": "/data",
      "description": "Data directory"
    }
  ],
  "ports": [
    {
      "name": "Web Port",
      "protocol": "tcp",
      "host": "5080",
      "container": "5080",
      "description": "Web interface port."
    }
  ],
  "variables": [
    {
      "name": "ZO_DATA_DIR",
      "key": "ZO_DATA_DIR",
      "value": "/data",
      "description": "Data directory",
      "required": true,
      "mask": true
    },
    {
      "name": "ZO_ROOT_USER_EMAIL",
      "key": "ZO_ROOT_USER_EMAIL",
      "value": "root@example.com",
      "description": "Email User",
      "required": true,
      "mask": false
    },
    {
      "name": "ZO_ROOT_USER_PASSWORD",
      "key": "ZO_ROOT_USER_PASSWORD",
      "value": "Complexpass#123",
      "description": "Root user password",
      "required": true,
      "mask": true
    }
  ]
}
