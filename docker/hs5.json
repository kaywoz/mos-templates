{
  "name": "HS5",
  "repo": "uroni/hs5:latest",
  "registry": "https://hub.docker.com/r/uroni/hs5",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "cpu_set": null,
  "web_ui_url": "http://[IP]:[PORT:8085]",
  "icon": "https://hs5.eu/assets/img/favicons/apple-touch-icon.png",
  "category": [ "Backup" ],
  "project": "https://github.com/uroni/hs5",
  "support": "https://github.com/uroni/hs5/issues",
  "donate": null,
  "description": "HS5 is a lightweight S3-compatible object storage server.",
  "paths": [
    {
      "name": "Data",
      "host": "/mnt/cache/appdata/hs5/data",
      "container": "/data",
      "mode": "rw",
      "description": "Object storage data directory.",
      "required": true
    },
    {
      "name": "Metadata",
      "host": "/mnt/cache/appdata/hs5/metadata",
      "container": "/metadata",
      "mode": "rw",
      "description": "Object storage metadata directory.",
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI / S3 API",
      "host": "8085",
      "container": "80",
      "protocol": "tcp",
      "description": "Web interface and S3-compatible API endpoint.",
      "required": true,
      "mask": false
    }
  ],
  "variables": [
    {
      "name": "Root Access Key",
      "key": "HS5_INIT_ROOT_ACCESS_KEY",
      "value": "root",
      "description": "Root user access key (S3 username). Only used on first initialisation.",
      "required": true,
      "mask": false
    },
    {
      "name": "Root Password",
      "key": "HS5_INIT_ROOT_PASSWORD",
      "value": "",
      "description": "Root user password. Only used on first initialisation.",
      "required": true,
      "mask": true
    },
    {
      "name": "Initial Bucket",
      "key": "HS5_INIT_CREATE_BUCKET",
      "value": "default",
      "description": "Name of the bucket to create on first initialisation.",
      "required": false,
      "mask": false
    }
  ],
  "devices": [],
  "labels": []
}