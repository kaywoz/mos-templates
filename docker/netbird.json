{
  "name": "Netbird",
  "repo": "netbirdio/netbird:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped --cap-add=NET_ADMIN --cap-add=SYS_ADMIN --cap-add=SYS_RESOURCE",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/netbird.png",
  "category": [
    "Utilities"
  ],
  "project": "https://github.com/netbirdio/netbird/",
  "support": "https://github.com/netbirdio/netbird/issues",
  "donate": null,
  "description": "NetBird combines a configuration-free peer-to-peer private network and a centralized access control system in a single platform, making it easy to create secure private networks for your organization or home.",
  "readme_url": "https://github.com/netbirdio/netbird/blob/main/README.md",
  "paths": [
    {
      "name": "Docker",
      "host": "/mnt/cache/appdata/netbird-client",
      "container": "/var/lib/netbird",
      "mode": "rw",
      "description": "Netbird dir.",
      "required": true
    }
  ],
  "ports": [],
  "variables": [
    {
      "name": "NB_SETUP_KEY",
      "key": "NB_SETUP_KEY",
      "value": "",
      "description": "Netbird setup key from https://app.netbird.io/setup-keys",
      "required": true,
      "mask": true
    }
  ],
  "devices": [],
  "labels": []
}
