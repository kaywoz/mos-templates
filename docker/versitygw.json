{
  "name": "VersityGW",
  "repo": "ghcr.io/versity/versitygw:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]",
  "icon": "https://github.com/versity/versitygw/raw/assets/assets/logo.svg",
  "category": [
    "Utilities"
  ],
  "project": "https://github.com/versity/versitygw",
  "support": "https://github.com/versity/versitygw/issues",
  "donate": null,
  "description": "A High-Performance S3 Translation Service",
  "readme_url": "https://github.com/versity/versitygw/blob/main/README.md",
  "paths": [
    {
      "name": "S3 object data (the gateway root)",
      "host": "/mnt/cache/appdata/versitygw/data/s3",
      "container": "/data/s3",
      "mode": "rw",
      "description": "S3 object data (the gateway root)",
      "required": true
    },
    {
      "name": "Shadow namespace for object versioning",
      "host": "/mnt/cache/appdata/versitygw/data/versioning",
      "container": "/data/versioning",
      "mode": "rw",
      "description": "Shadow namespace for object versioning",
      "required": true
    },
    {
      "name": "Flat-file IAM account storage",
      "host": "/mnt/cache/appdata/versitygw/data/iam",
      "container": "/data/iam",
      "mode": "rw",
      "description": "Flat-file IAM account storage",
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "8080",
      "container": "8080",
      "protocol": "tcp",
      "description": "Web interface port",
      "required": true,
      "mask": false
    },
    {
      "name": "Admin API (used by the WebUI)",
      "host": "7071",
      "container": "7071",
      "protocol": "tcp",
      "description": "Admin API (used by the WebUI)",
      "required": true,
      "mask": false
    },
    {
      "name": "S3 API",
      "host": "7070",
      "container": "7070",
      "protocol": "tcp",
      "description": "S3 API",
      "required": true,
      "mask": false
    }

  ],
  "variables": [
    {
      "Name": "ROOT_ACCESS_KEY",
      "Value": "[[ROOT_ACCESS_KEY]]",
      "Description": "Root S3 access key"
    },
    {
      "Name": "ROOT_SECRET_KEY",
      "Value": "[[ROOT_SECRET_KEY]]",
      "Description": "Root S3 secret key"
    },
    {
      "Name": "VGW_PORT",
      "Value": ":7070",
      "Description": "Internal S3 API listen port"
    },
    {
      "Name": "VGW_IAM_DIR",
      "Value": "/data/iam",
      "Description": "IAM data directory inside container"
    },
    {
      "Name": "VGW_VERSIONING_DIR",
      "Value": "/data/versioning",
      "Description": "Versioning metadata directory inside container"
    },
    {
      "Name": "VGW_BACKEND",
      "Value": "posix",
      "Description": "Storage backend type"
    },
    {
      "Name": "VGW_BACKEND_ARGS",
      "Value": "/data/s3",
      "Description": "POSIX backend root path inside container"
    },
    {
      "Name": "VGW_ADMIN_PORT",
      "Value": ":7071",
      "Description": "Internal admin API listen port"
    },
    {
      "Name": "VGW_WEBUI_PORT",
      "Value": ":8080",
      "Description": "Internal web UI listen port"
    },
    {
      "Name": "VGW_WEBUI_GATEWAYS",
      "Value": "http://[[SERVER_IP]]:[[S3_PORT]]",
      "Description": "Public S3 gateway URL shown in web UI"
    },
    {
      "Name": "VGW_WEBUI_ADMIN_GATEWAYS",
      "Value": "http://[[SERVER_IP]]:[[ADMIN_PORT]]",
      "Description": "Public admin gateway URL shown in web UI"
    }
  ],
  "devices": [],
  "labels": []
}
