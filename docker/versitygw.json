{
  "name": "VersityGW",
  "repo": "ghcr.io/versity/versitygw:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]",
  "icon": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/kopia.png",
  "category": [
    "Backup"
  ],
  "project": "https://github.com/kopia/kopia/",
  "support": "https://github.com/kopia/kopia/issues",
  "donate": null,
  "description": "Kopia is a fast and secure open-source backup/restore tool that allows you to create encrypted snapshots of your data and save the snapshots to remote or cloud storage of your choice, to network-attached storage or server, or locally on your machine.",
  "readme_url": "https://github.com/kopia/kopia/blob/master/README.md",
  "paths": [
    {
      "name": "S3 object data (the gateway root)",
      "host": "/mnt/cache/appdata/versitygw/data/s3",
      "container": "/data/s3",
      "mode": "rw",
      "description": "S3 object data (the gateway root)",
      "required": true
    },
    {
      "name": "Shadow namespace for object versioning",
      "host": "/mnt/cache/appdata/versitygw/data/versioning",
      "container": "/data/versioning",
      "mode": "rw",
      "description": "Shadow namespace for object versioning",
      "required": true
    },
    {
      "name": "Flat-file IAM account storage",
      "host": "/mnt/cache/appdata/versitygw/data/iam",
      "container": "/data/iam",
      "mode": "rw",
      "description": "Flat-file IAM account storage",
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "8080",
      "container": "8080",
      "protocol": "tcp",
      "description": "Web interface port",
      "required": true,
      "mask": false
    },
    {
      "name": "Admin API (used by the WebUI)",
      "host": "7071",
      "container": "7071",
      "protocol": "tcp",
      "description": "Admin API (used by the WebUI)",
      "required": true,
      "mask": false
    },
    {
      "name": "S3 API",
      "host": "7070",
      "container": "7070",
      "protocol": "tcp",
      "description": "S3 API",
      "required": true,
      "mask": false
    }

  ],
  "variables": [
    {
      "name": "ROOT_ACCESS_KEY",
      "key": "ROOT_ACCESS_KEY",
      "value": "supersecretpassword",
      "description": "ROOT_ACCESS_KEY",
      "required": true,
      "mask": false
    },
    {
      "name": "ROOT_SECRET_KEY",
      "key": "ROOT_SECRET_KEY",
      "value": "supersecretpassword",
      "description": "ROOT_SECRET_KEY",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_PORT",
      "key": "VGW_PORT",
      "value": ":7070",
      "description": "VGW_PORT",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_BACKEND",
      "key": "VGW_BACKEND",
      "value": "posix",
      "description": "VGW_BACKEND",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_ADMIN_PORT",
      "key": "VGW_ADMIN_PORT",
      "value": ":7071",
      "description": "VGW_ADMIN_PORT",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_BACKEND_ARGS",
      "key": "VGW_BACKEND_ARGS",
      "value": "/data/s3",
      "description": "VGW_BACKEND_ARGS",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_WEBUI_PORT",
      "key": "VGW_WEBUI_PORT",
      "value": ":8080",
      "description": "VGW_WEBUI_PORT",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_WEBUI_GATEWAYS",
      "key": "VGW_WEBUI_GATEWAYS",
      "value": "http://localhost:7070",
      "description": "VGW_WEBUI_GATEWAYS",
      "required": true,
      "mask": false
    },
    {
      "name": "VGW_WEBUI_ADMIN_GATEWAYS",
      "key": "VGW_WEBUI_ADMIN_GATEWAYS",
      "value": "http://localhost:7071",
      "description": "VGW_WEBUI_ADMIN_GATEWAYS",
      "required": true,
      "mask": false
    }
  ],
  "devices": [],
  "labels": []
}
