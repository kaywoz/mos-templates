{
  "name": "Copyparty",
  "repo": "ghcr.io/9001/copyparty-ac",
  "registry": "https://github.com/9001/copyparty/pkgs/container/copyparty-ac",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--user=500:500",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:3923]",
  "icon": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/copyparty.png",
  "category": null,
  "project": "https://github.com/9001/copyparty",
  "support": "https://github.com/9001/copyparty/issues",
  "description": "### 💾🎉 copyparty\r\n\r\nturn almost any device into a file server with resumable uploads/downloads using *any* (https://github.com/9001/copyparty/blob/hovudstraum/README.md#browser-support) web browser\r\n\r\nA full list of the feature set can be found here https://github.com/9001/copyparty/blob/hovudstraum/README.md#features",
  "paths": [
    {
      "name": "Config",
      "host": "/mnt/cache/appdata/copyparty",
      "container": "/cfg",
      "mode": "rw",
      "description": "Configuration directory",
      "required": true
    },
    {
      "name": "Temporary Data",
      "host": "/mnt/cache/appdata/copyparty/tmp",
      "container": "/tmp/copyparty",
      "mode": "rw",
      "description": "Salts, session DB, share DB",
      "required": true
    },
    {
      "name": "Storage",
      "host": "/mnt/user/share",
      "container": "/w",
      "mode": "rw",
      "description": "Directory to expose for file sharing",
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebGui",
      "host": "3923",
      "container": "3923",
      "protocol": "tcp",
      "description": null,
      "required": true,
      "mask": false
    }
  ],
  "variables": [  
    {
      "name": "LD_PRELOAD",
      "key": "LD_PRELOAD",
      "value": "/usr/lib/libmimalloc-secure.so.NOPE",
      "description": "enable mimalloc by replacing 'NOPE' with '2' for a nice speed-boost (will use twice as much ram)",
      "required": false,
      "mask": false
    }
  ],
  "devices": [],
  "labels": []
}
