{
  "name": "FileBrowser Quantum",
  "repo": "gtstef/filebrowser:stable",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:80]",
  "icon": "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/filebrowser-quantum.png",
  "category": [
    "Utilities"
  ],
  "project": "https://github.com/gtsteffaniak/filebrowser",
  "support": "https://github.com/gtsteffaniak/filebrowser/issues",
  "donate": null,
  "description": "The best free self-hosted web-based file manager.",
  "readme_url": "https://github.com/linuxserver/docker-kavita/blob/main/README.md",
  "paths": [
    {
      "name": "Config",
      "host": "/mnt/cache/appdata/filebrowser-quantum",
      "container": "/data",
      "mode": "rw",
      "description": "Configuration directory.",
      "required": true
    },
    {
      "name": "Share Data",
      "host": "/mnt/user/share",
      "container": "/srv",
      "mode": "rw",
      "description": "Directory to expose through the file browser.",
      "required": true
    },
    {
      "name": "Database",
      "host": "/mnt/cache/appdata/filebrowser-quantum/database",
      "container": "/home/filebrowser/data",
      "mode": "rw",
      "description": "Database directory for filebrowser.",
      "required": false
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "80",
      "container": "80",
      "protocol": "tcp",
      "description": "Web interface",
      "required": false,
      "mask": false
    }
  ],
  "variables": [],
  "devices": [],
  "labels": []
}
