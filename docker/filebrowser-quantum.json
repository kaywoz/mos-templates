{
  "name": "FileBrowser Quantum",
  "repo": "gtstef/filebrowser:stable",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:80]",
  "readme_url": "https://github.com/linuxserver/docker-kavita/blob/main/README.md",
  "icon": "https://filebrowserquantum.com/logo.svg",
  "category": [ "media" ],
  "project": "https://github.com/gtsteffaniak/filebrowser",
  "support": "https://github.com/gtsteffaniak/filebrowser/issues",
  "description": "The best free self-hosted web-based file manager. ",
  "donate": null,
  "paths": [
    {
      "name": "Share data",
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/data/to/share",
      "container": "/srv",
      "description": "Share data"
    },
    {
      "name": "Config",
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/filebrowser-quantum/data",
      "container": "/data",
      "description": "Config directory"
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "protocol": "tcp",
      "host": "80",
      "container": "80",
      "description": "Web interface"
    }
  ],
  "variables": [],
  "devices": []
}
