{
  "name": "syslog-ng",
  "repo": "lscr.io/linuxserver/syslog-ng:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped ",
  "post_parameters": null,
  "web_ui_url": null,
  "readme_url": "https://github.com/linuxserver/docker-syslog-ng/blob/main/README.md",
  "icon": "https://raw.githubusercontent.com/linuxserver/docker-templates/master/linuxserver.io/img/syslog-ng-logo.png",
  "category": [ "utilities" ],
  "project": "https://github.com/linuxserver/docker-syslog-ng",
  "support": "https://github.com/linuxserver/docker-syslog-ng/issues",
  "description": "syslog-ng allows you to flexibly collect, parse, classify, rewrite and correlate logs from across your infrastructure and store or route them to log analysis tools.",
  "donate": null,
  "paths": [
    {
      "name": "Config directory" ,
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/syslog-ng/config",
      "container": "/config",
      "description": "Config directory"
    },
    {
      "name": "Log directory" ,
      "mode": "rw",
      "host": "/mnt/PLACEHOLDER/syslog-ng/log",
      "container": "/var/log",
      "description": "Log directory"
    }
  ],
  "ports": [
     {
      "name": "Syslog Port",
      "protocol": "udp",
      "host": "514",
      "container": "5514",
      "description": "Syslog Port"
    },
     {
      "name": "Syslog over TCP",
      "protocol": "tcp",
      "host": "601",
      "container": "6601",
      "description": "Syslog over TCP"
    },
     {
      "name": "Syslog over TLS",
      "protocol": "tcp",
      "host": "6514",
      "container": "6514",
      "description": "Syslog over TLS"
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "1000",
      "description": "User ID",
      "required": true,
      "mask": false
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "1000",
      "description": "Group ID",
      "required": true,
      "mask": false
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Etc/UTC",
      "description": "Timezone",
      "required": true,
      "mask": false
    },
    {
      "name": "LOG_TO_STDOUT",
      "key": "LOG_TO_STDOUT",
      "value": null,
      "description": "f set to true container will log to stdout, otherwise will log to /config/log/",
      "required": false,
      "mask": false
    }
  ]
}
