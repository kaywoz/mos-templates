{
  "name": "komga",
  "repo": "gotson/komga:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:25600]/",
  "readme_url": "https://github.com/gotson/komga/blob/master/README.md",
  "icon": "https://github.com/gotson/komga/blob/master/.github/readme-images/app-icon.png?raw=true",
  "category": [ "media" ],
  "project": "https://github.com/gotson/komga",
  "support": "https://github.com/gotson/komga/issues",
  "description": "Komga is a free and open source comics/mangas/media server. It allows you to manage and read your local comics, manga, and books from a modern web interface with support for multiple users, OPDS, and mobile apps.",
  "donate": "https://github.com/sponsors/gotson",
  "paths": [
    {
      "name": "Config",
      "mode": "rw",
      "host": "/mnt/cache/appdata/komga",
      "container": "/config",
      "description": "Komga configuration and database."
    },
    {
      "name": "Comics",
      "mode": "ro",
      "host": "/mnt/cache/media/comics",
      "container": "/data/comics",
      "description": "Your comics and manga library folder."
    },
    {
      "name": "Books",
      "mode": "ro",
      "host": "/mnt/cache/media/books",
      "container": "/data/books",
      "description": "Optional: Additional books folder."
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "25600",
      "container": "25600",
      "description": "Komga web interface port."
    }
  ],
  "variables": [
    {
      "name": "PUID",
      "key": "PUID",
      "value": "500",
      "mask": false,
      "description": "User ID for file permissions."
    },
    {
      "name": "PGID",
      "key": "PGID",
      "value": "500",
      "mask": false,
      "description": "Group ID for file permissions."
    },
    {
      "name": "TZ",
      "key": "TZ",
      "value": "Europe/Vienna",
      "mask": false,
      "description": "Timezone for the container."
    }
  ],
  "devices": [],
  "gpus": []
}