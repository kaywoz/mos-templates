{
  "name": "Scrutiny",
  "repo": "ghcr.io/analogj/scrutiny:latest-omnibus",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped --cap-add SYS_RAWIO --cap-add SYS_ADMIN --device=/dev/sda --device=/dev/sdb --device=/dev/sdc --device=/dev/nvme0 --device=/dev/nvme1",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]",
  "icon": "https://github.com/AnalogJ/scrutiny/raw/master/webapp/frontend/src/assets/images/logo/scrutiny-logo-dark.png",
  "category": [
    "Utilities"
  ],
  "project": "https://github.com/AnalogJ/scrutiny",
  "support": "https://github.com/AnalogJ/scrutiny/issues",
  "donate": null,
  "description": "WebUI for smartd S.M.A.R.T monitoring",
  "readme_url": "https://github.com/AnalogJ/scrutiny/blob/master/README.md",
  "paths": [
    {
      "name": "Config",
      "host": "/mnt/cache/appdata/scrutiny",
      "container": "/opt/scrutiny/config",
      "mode": "rw",
      "description": null,
      "required": true
    },
    {
      "name": "InfluxDB",
      "host": "/mnt/cache/appdata/scrutiny/influxdb2",
      "container": "/opt/scrutiny/influxdb",
      "mode": "rw",
      "description": null,
      "required": true
    },
    {
      "name": "Docker socket",
      "host": "/run/udev",
      "container": "/run/udev",
      "mode": "ro",
      "description": null,
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "8080",
      "container": "8080",
      "protocol": "tcp",
      "description": "Web interface port for viewing container logs.",
      "required": false,
      "mask": false
    },
    {
      "name": "InfluxDB Port",
      "host": "8086",
      "container": "8086",
      "protocol": "tcp",
      "description": "InfluxDB",
      "required": false,
      "mask": false
    }
  ],
  "variables": [],
  "devices": [],
  "labels": []
}
