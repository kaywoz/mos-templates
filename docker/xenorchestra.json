{
  "name": "Xen Orchestra",
  "repo": "ronivay/xen-orchestra:latest",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "sh",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped --stop-timeout 60 --cap-add sys_admin --cap-add sys_admin --security-opt apparmor:unconfined",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:80]",
  "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/xen-orchestra.png",
  "category": [
    "Utilities"
  ],
  "project": "https://github.com/ronivay/xen-orchestra-docker",
  "support": "https://github.com/ronivay/xen-orchestra-docker/issues",
  "donate": null,
  "description": "This repository contains files to build Xen-Orchestra community edition docker container with all features and plugins installed.",
  "readme_url": "https://github.com/ronivay/xen-orchestra-docker/blob/master/README.md",
  "paths": [
    {
      "name": "XOServer",
      "host": "/mnt/cache/appdata/xo-server",
      "container": "/var/lib/xo-server",
      "mode": "rw",
      "description": null,
      "required": true
    },
    {
      "name": "Redis",
      "host": "/mnt/cache/appdata/xo-server/redis",
      "container": "/var/lib/redis",
      "mode": "rw",
      "description": null,
      "required": true
    }
  ],
  "ports": [
    {
      "name": "WebUI Port",
      "host": "80",
      "container": "80",
      "protocol": "tcp",
      "description": "Web interface port for Xen Orchestra.",
      "required": false,
      "mask": false
    }
  ],
  "variables": [],
  "devices": [
    {
      "name": "FUSE",
      "host": "/dev/fuse",
      "container": "/dev/fuse",
      "description": null,
      "required": false
    },
    {
      "name": "loop-control",
      "host": "/dev/loop-control",
      "container": "/dev/loop-control",
      "description": null,
      "required": false
    },
    {
      "name": "loop0",
      "host": "/dev/loop0",
      "container": "/dev/loop0",
      "description": null,
      "required": false
    }
  ],
  "labels": []
}
